alias vim="nvim"
alias phpdir="cd /var/www/html/"
alias pp="cd ~/personal-projects && ls"
alias notes="tmux a -t notes"
alias fman="compgen -c | fzf | xargs man"
alias ls="eza"
alias ll="eza -lah"
alias cat="bat"
alias grep="rg"
alias sysmon="tmux attach -t sysmon"
alias dotfiles="cd ~/.dotfiles/ && ll && gst"
alias projects="bash ~/scripts/work-session.sh"

