Host *
    AddKeysToAgent yes
    IdentitiesOnly yes

Host github-personal
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_personal

Host github-work
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_work

Host rpi
    HostName rpi.local
    User riaan
    Port 22

Host arch
    HostName arch.local
    User riaan
    Port 22

Host yappit-ec2
    HostName ec2-51-21-152-250.eu-north-1.compute.amazonaws.com
    User ubuntu
    Port 22
    IdentityFile ~/.ssh/aws-ssh.pem
